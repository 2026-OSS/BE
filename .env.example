AI_SERVER_URL=http://127.0.0.1:8001
AI_PREDICT_PATH=/predict
AI_FRAME_FIELD_NAME=frame

OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_RESPONSE_FORMAT=mp3
OPENAI_TTS_TIMEOUT=30

PAGE_CONFIDENCE_THRESHOLD=0.75
PAGE_CLASSIFIER_ENABLED=false
PAGE_CLASSIFIER_CONFIDENCE_THRESHOLD=0.75
PAGE_CLASSIFIER_IMAGE_SIZE=224
PAGE_CLASSIFIER_MODEL_PATH=app/data/page_classifier/page_classifier_mobilenetv2.keras
PAGE_CLASSIFIER_CLASS_NAMES_PATH=app/data/page_classifier/class_names.json

MATCH_DISTANCE_THRESHOLD=80
MATCH_BBOX_PADDING=24
